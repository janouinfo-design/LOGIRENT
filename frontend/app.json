{
  "expo": {
    "name": "LogiRent",
    "slug": "logirent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "logirent",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ch.logirent.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "LogiRent utilise la camera pour scanner vos documents et photographier les vehicules.",
        "NSPhotoLibraryUsageDescription": "LogiRent accede a vos photos pour telecharger vos documents d'identite et permis de conduire.",
        "NSLocationWhenInUseUsageDescription": "LogiRent utilise votre position pour trouver les agences les plus proches."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "edgeToEdgeEnabled": true,
      "package": "ch.logirent.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#7C3AED"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "LogiRent accede a vos photos pour telecharger vos documents.",
          "cameraPermission": "LogiRent utilise la camera pour scanner vos documents."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "owner": "YOUR_EXPO_USERNAME",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR_EAS_PROJECT_ID"
    }
  }
}
